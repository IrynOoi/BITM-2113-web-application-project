# ================================
# XAMPP / Server Files
# ================================
# Ignore XAMPP specific files
/xampp/
htdocs/

# ================================
# Backend (PHP)
# ================================
# Environment configuration
backend/config/database.php
backend/config/config.php
.env

# Composer dependencies
vendor/
composer.lock

# Uploaded files (keep folder structure, ignore contents)
backend/uploads/receipts/*
backend/uploads/images/*
!backend/uploads/receipts/.gitkeep
!backend/uploads/images/.gitkeep

# PHP error logs
*.log
error_log

# ================================
# Frontend
# ================================
# Node modules (if using npm)
node_modules/
package-lock.json

# Build files (if using build tools)
dist/
build/

# ================================
# IDE & Editor Files
# ================================
# VS Code
.vscode/
*.code-workspace

# IntelliJ IDEA
.idea/
*.iml

# Sublime Text
*.sublime-project
*.sublime-workspace

# ================================
# Operating System Files
# ================================
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Linux
*~
.directory

# ================================
# Media & Large Files
# ================================
# Video files (too large for GitHub)
frontend/assets/video/*.mp4
!frontend/assets/video/.gitkeep

# High-res images (keep low-res placeholders)
frontend/assets/images/*.psd
frontend/assets/images/*.ai

# ================================
# Temp & Cache Files
# ================================
*.tmp
*.temp
*.cache
*.swp
*.swo

# ================================
# Security
# ================================
# Passwords and keys
*.pem
*.key
credentials.json
config.local.php

# ================================
# Project Specific
# ================================
# Test files
test.php
phpinfo.php

# SQLite database files
*.sqlite
*.db

# Composer phar
composer.phar

# ================================
# Keep Empty Folders
# ================================
# Allow .gitkeep files to maintain folder structure